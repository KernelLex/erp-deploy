# Copy this file to .env and fill in your values
# cp .env.example .env

# ERPNext site name — use your server domain or IP
# This becomes the MariaDB site identifier AND the ERPNext host header
SITE_NAME=erp.yourdomain.com

# Domain where the React frontend will be served (can be a subdomain or IP)
FRONTEND_DOMAIN=app.yourdomain.com

# MariaDB root password (strong password required)
DB_ROOT_PASSWORD=changeme_db_root

# ERPNext admin panel password
ADMIN_PASSWORD=changeme_admin

# hr_client app git repo (SSH or HTTPS)
# SSH  : git@github.com:KernelLex/hr-client-erp.git
# HTTPS: https://github.com/KernelLex/hr-client-erp.git
HR_CLIENT_REPO=https://github.com/KernelLex/hr-client-erp.git

# ─── Optional: AI Job Description Generator ───────────────────────────────────
# Uncomment ONE of these when you pick an AI provider
# VITE_OPENAI_API_KEY=sk-...
# VITE_GROQ_API_KEY=gsk_...
