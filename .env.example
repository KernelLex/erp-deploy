# Copy this file to .env and fill in your values
# cp .env.example .env

# Your Linux server's IP address (e.g. 192.168.1.100)
SERVER_IP=YOUR_SERVER_IP

# ERPNext site name — use your server IP or a domain
SITE_NAME=erp.localhost

# Database password (choose a strong password)
DB_ROOT_PASSWORD=changeme_db_root

# ERPNext admin panel password
ADMIN_PASSWORD=changeme_admin

# ─── Optional: AI Job Description Generator ───────────────────────────────────
# Uncomment ONE of these when you pick an AI provider
# VITE_OPENAI_API_KEY=sk-...
# VITE_GROQ_API_KEY=gsk_...
